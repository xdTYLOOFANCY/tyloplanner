# Copy this file to .env and fill in what you need.

# --- Login (recommended!) ---
# If AUTH_PASSWORD is empty, TyloPlanner runs WITHOUT a login screen.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-to-something-strong

# Session signing key. Optional: a random one is generated and stored in the
# database on first run. Set it explicitly if you want sessions to survive
# a database reset.
#SECRET_KEY=

# Public URL where the app is reachable (used for the calendar feed URL
# and the Strava OAuth redirect). For local use, leave the default.
APP_URL=http://localhost:8000

# --- Strava (optional) ---
# 1. Go to https://www.strava.com/settings/api and create an app (free).
# 2. Set "Authorization Callback Domain" to: localhost
#    (or your own domain if you host it publicly)
# 3. Copy the Client ID and Client Secret below, restart the container,
#    then click "Connect Strava" in Settings.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
