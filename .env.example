# Copy this file to .env and fill in what you need.

# --- Login ---
# Normally you leave these EMPTY: on your first visit the app shows a
# setup screen where you pick a username and password (stored in the
# database, changeable later under Settings -> Security).
# Setting AUTH_USERNAME/AUTH_PASSWORD here instead pre-creates that
# account on first run and skips the setup screen (legacy behavior).
AUTH_USERNAME=admin
AUTH_PASSWORD=

# Session signing key. Optional: a random one is generated and stored in the
# database on first run. Set it explicitly if you want sessions to survive
# a database reset.
#SECRET_KEY=

# Public URL where the app is reachable (used for the calendar feed URL
# and the Strava OAuth redirect). For local use, leave the default. For remote access through network/ tailscale replace localhost with the host ip-adress, make sure to have set a static-ip for the host device first.
APP_URL=http://localhost:8000

# --- Strava (optional) ---
# 1. Go to https://www.strava.com/settings/api and create an app (free).
# 2. Set "Authorization Callback Domain" to: localhost
#    (or your own domain if you host it publicly)
# 3. Copy the Client ID and Client Secret below, restart the container,
#    then click "Connect Strava" in Settings.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
